# Copy this file to .env and fill in the values.
# The .env file is loaded automatically by Docker Compose.

# ── SearXNG ──────────────────────────────────────────────────────────────────

# Host port that SearXNG will be reachable on (default: 8888).
SEARXNG_PORT=8888

# Public base URL.  Change this if SearXNG is behind a reverse proxy.
SEARXNG_BASE_URL=http://localhost:8888/

# A long random secret key used to sign cookies.
# Generate one with:  openssl rand -hex 32
SEARXNG_SECRET_KEY=changeme-use-a-long-random-secret
